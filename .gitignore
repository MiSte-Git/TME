# Python artifacts
__pycache__/
*.py[codz]
*$py.class

# Build / dist
build/
dist/
.eggs/
*.egg-info/
# Von PyInstaller (build_win.ps1/build_linux.sh) als Nebeneffekt im Repo-Root
# erzeugt, wenn kein bestehendes .spec als Ziel uebergeben wird - TME_mac.spec
# ist dagegen bewusst eingecheckt (siehe build_mac.sh), daher kein *.spec.
/TME.spec

# Virtual envs and local env files
.venv/
.venv-build/
venv/
env/
.env
.envrc

# Tools caches
.ruff_cache/
.mypy_cache/
.pytest_cache/
.cache/

# Docs build
docs/_build/

# Project-specific runtime/output
_archive/
cache/
output/
data/
media/
input/*
!input/example.json
!input/links.txt
out/
*.bak
*.session
*.session-journal
*.desktop

# Git internals
.git

# Allow images in repo (no global *.png ignore)
